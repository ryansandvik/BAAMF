# ============================================================
# BAAMF — .gitignore
# ============================================================

# --- Secrets (never commit) ---------------------------------
Config.xcconfig
GoogleService-Info.plist
Production.p8
Sandbox.p8

# --- Xcode --------------------------------------------------
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
DerivedData/
*.hmap
*.ipa
*.xcarchive
xcuserdata/

# --- macOS --------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# --- Swift Package Manager ----------------------------------
.build/
.swiftpm/

# --- CocoaPods (not used, but just in case) -----------------
Pods/
Podfile.lock

# --- TestFlight / Archives ----------------------------------
*.ipa
*.dSYM.zip
*.dSYM
