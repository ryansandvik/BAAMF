// Config.xcconfig.example
// ✅ This file IS committed to git — it's a template only (no real secrets).
// To set up locally: cp Config.xcconfig.example Config.xcconfig
// Then replace REPLACE_WITH_YOUR_API_KEY with your actual key.

GOOGLE_BOOKS_API_KEY = REPLACE_WITH_YOUR_API_KEY
INFOPLIST_KEY_GOOGLE_BOOKS_API_KEY = $(GOOGLE_BOOKS_API_KEY)
